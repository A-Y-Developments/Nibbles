default_platform(:ios)

PROJECT_ROOT = File.expand_path("../..", __dir__)
APP_IDENTIFIER = ENV["APP_IDENTIFIER"] || "com.aydev.nibbles"
TEAM_ID = ENV["APPLE_TEAM_ID"] || "32T8HNVYGX"
IPA_GLOB = File.join(PROJECT_ROOT, "build/ios/ipa/*.ipa")

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT"),
    is_key_content_base64: true,
    in_house: false,
  )
end

def write_export_options(signing_style)
  profiles = ""
  if signing_style == "manual"
    profile_name = ENV.fetch("sigh_#{APP_IDENTIFIER}_appstore_profile-name")
    profiles = <<~XML
      <key>provisioningProfiles</key>
      <dict>
        <key>#{APP_IDENTIFIER}</key>
        <string>#{profile_name}</string>
      </dict>
    XML
  end

  plist = <<~XML
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>method</key>
      <string>app-store</string>
      <key>teamID</key>
      <string>#{TEAM_ID}</string>
      <key>signingStyle</key>
      <string>#{signing_style}</string>
      <key>uploadSymbols</key>
      <true/>
      <key>destination</key>
      <string>export</string>
    #{profiles}</dict>
    </plist>
  XML

  path = File.join(PROJECT_ROOT, "ios/ExportOptions.plist")
  File.write(path, plist)
  path
end

def run_outside_bundler(&block)
  if defined?(Bundler) && Bundler.respond_to?(:with_unbundled_env)
    Bundler.with_unbundled_env(&block)
  else
    yield
  end
end

def build_prod_ipa(signing_style, build_number)
  write_export_options(signing_style)
  FileUtils.rm_rf(File.join(PROJECT_ROOT, "build/native_assets"))
  args = [
    "flutter", "build", "ipa",
    "--release",
    "--flavor", "prod",
    "-t", "lib/main.dart",
    "--export-options-plist=ios/ExportOptions.plist",
  ]
  args << "--build-number=#{build_number}" unless build_number.nil?

  Dir.chdir(PROJECT_ROOT) do
    run_outside_bundler { sh(*args) }
  end
end

platform :ios do
  desc "Archive prod with local/automatic signing — no upload, no API key. Validates the build."
  lane :build_only do
    build_prod_ipa("automatic", nil)
    UI.success("IPA: #{Dir[IPA_GLOB].first}")
  end

  desc "Upload an already-built IPA to TestFlight. Requires ASC API key env."
  lane :upload_latest do
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      ipa: Dir[IPA_GLOB].first,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc "Build prod and upload to TestFlight. Requires ASC API key env."
  lane :beta do
    setup_ci
    api_key = asc_api_key
    signing_style = ENV["SIGNING"] == "manual" ? "manual" : "automatic"

    if signing_style == "manual"
      sync_code_signing(type: "appstore", api_key: api_key, readonly: true)
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "Runner.xcodeproj",
        team_id: TEAM_ID,
        code_sign_identity: "Apple Distribution",
        bundle_identifier: APP_IDENTIFIER,
        profile_name: ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"],
        targets: ["Runner"],
      )
    end

    build_number = begin
      latest_testflight_build_number(app_identifier: APP_IDENTIFIER, api_key: api_key) + 1
    rescue StandardError
      1
    end

    build_prod_ipa(signing_style, build_number)

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      ipa: Dir[IPA_GLOB].first,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end
end
